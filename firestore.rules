rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // dados/g__app — leitura pública (nome do sistema na tela de login)
    match /dados/g__app {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Todos os dados em /dados/{doc} — requer autenticação
    // Cobre globais (dados/g__*) e filiais (dados/f1__*, etc.)
    match /dados/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
