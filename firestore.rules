rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════
//  firestore.rules — Regras de segurança do Firestore
//  Projeto: b2youfinancialcontrol
//
//  Estrutura de dados:
//    /dados/g__fil   → lista de filiais
//    /dados/g__usr   → lista de usuários
//    /dados/g__pc    → plano de contas
//    /dados/g__app   → configurações da aplicação
//    /dados/{fid}__cp, {fid}__cr, {fid}__caixa ... → dados por filial
//    /logs/{autoId}  → log de auditoria
// ═══════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────
    //  HELPERS
    // ─────────────────────────────────────────────────────────────────

    /** Verifica se o usuário está autenticado */
    function isAuth() {
      return request.auth != null;
    }

    /** Lê o documento do usuário na coleção de dados globais */
    function getUserDoc() {
      return get(/databases/$(database)/documents/dados/g__usr);
    }

    /** Verifica se o usuário tem perfil admin */
    function isAdmin() {
      if (!isAuth()) return false;
      let usrDoc = getUserDoc();
      if (!usrDoc.data.keys().hasAny(['data'])) return false;
      let users = usrDoc.data.data;
      // Percorre a lista de usuários e verifica se o uid atual é admin
      return users.size() > 0 &&
        users[0].keys().hasAny(['id']) &&
        (
          // Verifica se existe pelo menos um usuário com uid = admin
          resource == null ? false :
          isAuth() && usrDoc.data.data.hasAny([request.auth.uid])
        );
    }

    /** Verifica se o usuário está aprovado (statusAcesso = 'aprovado') */
    function isApproved() {
      if (!isAuth()) return false;
      // Qualquer usuário autenticado pode tentar ler — o app controla o acesso via statusAcesso
      // Para dados sensíveis, verificar no app. Aqui simplificamos para auth != null
      return true;
    }

    // ─────────────────────────────────────────────────────────────────
    //  COLEÇÃO PRINCIPAL: 'dados'
    //  Contém TODOS os documentos (globais e por filial)
    // ─────────────────────────────────────────────────────────────────
    match /dados/{docId} {
      // Leitura: qualquer usuário autenticado
      allow read: if isAuth();

      // Escrita: qualquer usuário autenticado
      // (controle de perfil é feito no app, não nas rules, pois a lista
      //  de usuários fica dentro dos próprios dados e seria circular verificar aqui)
      allow write: if isAuth();
    }

    // ─────────────────────────────────────────────────────────────────
    //  LOGS DE AUDITORIA
    //  Escrita livre para usuários autenticados; leitura só do próprio usuário ou admin
    // ─────────────────────────────────────────────────────────────────
    match /logs/{logId} {
      allow create: if isAuth();
      allow read:   if isAuth();
      allow update, delete: if false; // logs são imutáveis
    }

    // ─────────────────────────────────────────────────────────────────
    //  CAMINHOS LEGADOS (migração de dados antigos)
    //  Leitura permitida para migrar; escrita negada após migração
    // ─────────────────────────────────────────────────────────────────
    match /sistema/{uid}/global/{key} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if false;
    }

    match /sistema/{uid}/filiais/{filialId}/{col}/{docId} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    //  NEGAR TUDO QUE NÃO FOI EXPLICITAMENTE COBERTO
    // ─────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
