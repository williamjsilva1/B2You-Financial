rules_version = '2';

// ══════════════════════════════════════════════════════════════
// B2You Financial Control — Firestore Security Rules
// Projeto: b2youfinancialcontrol
// ══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }

    // Todos os documentos em /dados/* — somente autenticados
    match /dados/{document} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // Logs — somente autenticados
    match /logs/{logId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if isAuth();
    }

    // Bloqueia qualquer outro caminho
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
